# Production environment — copy to .env.production and fill in values
# Never commit .env.production to git

# LLM
OPENAI_API_KEY=sk-...
LITELLM_MASTER_KEY=sk-rayzen-prod-...
LITELLM_BASE_URL=http://litellm:4000/v1

# Database (use a strong password)
POSTGRES_PASSWORD=changeme-strong-password
DATABASE_URL=postgresql://rayzen:changeme-strong-password@postgres:5432/rayzen_ai

# Redis
REDIS_URL=redis://redis:6379

# Auth
JWT_SECRET=<openssl rand -hex 32>
JWT_AGENT_EXPIRY=30d

# API / Web
API_PORT=3001
WEB_PORT=3000
NODE_ENV=production

# PC Agent
AGENT_API_URL=https://YOUR_DOMAIN/api
AGENT_TOKEN=<generate via POST /auth/agent-token>
AGENT_POLL_INTERVAL_MS=3000

# Frontend (Next.js public env)
NEXT_PUBLIC_API_URL=https://YOUR_DOMAIN/api

# Obsidian (server-side path where API runs)
# Leave empty if not used in VPS context
OBSIDIAN_VAULT_PATH=
OBSIDIAN_VAULT_NAME=
