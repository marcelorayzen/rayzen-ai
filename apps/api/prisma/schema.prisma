generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("active")
  goals       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  documents            Document[]
  conversationMessages ConversationMessage[]
  events               Event[]
  sessionArtifacts     SessionArtifact[]
  projectDocuments     ProjectDocument[]
  projectState         ProjectState?

  @@map("projects")
}

model ProjectDocument {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  type        String    // project_state | decisions_log | next_actions | work_journal
  content     String    // markdown gerado
  generatedAt DateTime  @default(now()) @map("generated_at")
  reviewedAt  DateTime? @map("reviewed_at")

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, type])
  @@map("project_documents")
}

model SessionArtifact {
  id        String   @id @default(uuid())
  projectId String?  @map("project_id")
  sessionId String   @map("session_id")
  type      String   @default("synthesis") // synthesis | summary
  content   Json     // { summary, decisions[], next_steps[], learnings[] }
  createdAt DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id])

  @@index([projectId, sessionId])
  @@map("session_artifacts")
}

model Event {
  id        String   @id @default(uuid())
  projectId String?  @map("project_id")
  source    String   // chat | memory | cli | voice | execution | manual
  type      String   // message | index | execution | decision | note | error
  intent    String?  // decision | idea | problem | reference | checkpoint
  content   String
  metadata  Json     @default("{}")
  ts        DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id])

  @@index([projectId, ts(sort: Desc)])
  @@map("events")
}

model ProjectState {
  id              String   @id @default(uuid())
  projectId       String   @unique @map("project_id")
  objective       String?
  stage           String?  // discovery | building | stabilizing | maintaining | paused
  blockers        Json     @default("[]")
  recentDecisions Json     @default("[]") @map("recent_decisions")
  nextSteps       Json     @default("[]") @map("next_steps")
  risks           Json     @default("[]")
  docGaps         Json     @default("[]") @map("doc_gaps")
  riskLevel       String   @default("low") @map("risk_level") // low | medium | high
  updatedAt       DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("project_states")
}

model Document {
  id         String   @id @default(uuid())
  sourcePath String?  @map("source_path")
  content    String
  embedding  Unsupported("vector(1024)")?
  metadata   Json     @default("{}")
  checksum   String
  projectId  String?  @map("project_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project Project? @relation(fields: [projectId], references: [id])

  @@map("documents")
}

model TaskLog {
  id        String   @id @default(uuid())
  module    String
  action    String
  payload   Json
  status    String   @default("pending")
  result    Json?
  error     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("task_logs")
}

model ConversationMessage {
  id             String   @id @default(uuid())
  sessionId      String   @map("session_id")
  module         String
  role           String
  content        String
  tokensUsed     Int?     @map("tokens_used")
  projectId      String?  @map("project_id")
  createdAt      DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id])

  @@map("conversation_messages")
}
