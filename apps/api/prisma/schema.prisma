generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("active")
  goals       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  documents            Document[]
  conversationMessages ConversationMessage[]
  events               Event[]
  sessionArtifacts     SessionArtifact[]
  projectDocuments     ProjectDocument[]
  projectState         ProjectState?
  recommendations      ProjectRecommendation[]
  healthScores         ProjectHealthScore[]

  @@map("projects")
}

model ProjectDocument {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  type        String    // project_state | decisions_log | next_actions | work_journal
  content     String    // markdown gerado
  generatedAt DateTime  @default(now()) @map("generated_at")
  reviewedAt  DateTime? @map("reviewed_at")

  project  Project                  @relation(fields: [projectId], references: [id])
  versions ProjectDocumentVersion[]

  @@unique([projectId, type])
  @@map("project_documents")
}

model ProjectDocumentVersion {
  id              String   @id @default(uuid())
  documentId      String   @map("document_id")
  content         String   // conteúdo desta versão
  previousContent String?  @map("previous_content") // conteúdo anterior (null na primeira versão)
  diff            String?  // diff resumido: linhas adicionadas/removidas
  reason          String   @default("regenerated") // regenerated | force_regenerated | manual
  sourceIds       Json     @default("[]") @map("source_ids") // IDs de events + artifacts usados
  createdAt       DateTime @default(now()) @map("created_at")

  document ProjectDocument @relation(fields: [documentId], references: [id])

  @@index([documentId, createdAt(sort: Desc)])
  @@map("project_document_versions")
}

model SessionArtifact {
  id        String   @id @default(uuid())
  projectId String?  @map("project_id")
  sessionId String   @map("session_id")
  type      String   @default("synthesis") // synthesis | checkpoint
  content   Json     // { summary, decisions[], next_steps[], learnings[], confidence }
  sourceIds Json     @default("[]") @map("source_ids") // IDs dos eventos usados para gerar
  createdAt DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id])

  @@index([projectId, sessionId])
  @@map("session_artifacts")
}

model Event {
  id          String   @id @default(uuid())
  projectId   String?  @map("project_id")
  source      String   // chat | memory | cli | voice | execution | manual
  type        String   // message | index | execution | decision | note | error
  intent      String?  // decision | idea | problem | reference | checkpoint
  content     String
  metadata    Json     @default("{}")
  ts          DateTime @default(now())
  memoryClass String   @default("inbox") @map("memory_class") // inbox | working | consolidated | archive

  project Project? @relation(fields: [projectId], references: [id])

  @@index([projectId, ts(sort: Desc)])
  @@index([projectId, memoryClass])
  @@map("events")
}

model ProjectRecommendation {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  type        String    // inactivity | doc_stale | blocker_stuck | next_step_pending | consistency
  title       String
  description String
  priority    String    @default("medium") // low | medium | high
  action      String?   // texto da ação sugerida
  dismissedAt DateTime? @map("dismissed_at")
  computedAt  DateTime  @default(now()) @map("computed_at")

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId, dismissedAt])
  @@map("project_recommendations")
}

model ProjectState {
  id               String   @id @default(uuid())
  projectId        String   @unique @map("project_id")
  objective        String?
  stage            String?  // discovery | building | stabilizing | maintaining | paused
  blockers         Json     @default("[]")
  recentDecisions  Json     @default("[]") @map("recent_decisions")
  nextSteps        Json     @default("[]") @map("next_steps")
  risks            Json     @default("[]")
  docGaps          Json     @default("[]") @map("doc_gaps")
  riskLevel        String   @default("low") @map("risk_level") // low | medium | high
  // Fase 11 — Planejamento operacional
  milestones       Json     @default("[]")   // { id, title, status: pending|active|done }[]
  backlog          Json     @default("[]")   // { id, title, priority: high|medium|low }[]
  activeFocus      String?  @map("active_focus")
  definitionOfDone String?  @map("definition_of_done")
  updatedAt        DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("project_states")
}

model ProjectHealthScore {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  score      Int      // 0–100
  breakdown  Json     // { activity, documentation, consistency, nextSteps, blockers, focus }
  createdAt  DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId, createdAt(sort: Desc)])
  @@map("project_health_scores")
}

model Document {
  id         String   @id @default(uuid())
  sourcePath String?  @map("source_path")
  content    String
  embedding  Unsupported("vector(1024)")?
  metadata   Json     @default("{}")
  checksum   String
  projectId  String?  @map("project_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project Project? @relation(fields: [projectId], references: [id])

  @@map("documents")
}

model TaskLog {
  id        String   @id @default(uuid())
  module    String
  action    String
  payload   Json
  status    String   @default("pending")
  result    Json?
  error     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("task_logs")
}

model ConversationMessage {
  id             String   @id @default(uuid())
  sessionId      String   @map("session_id")
  module         String
  role           String
  content        String
  tokensUsed     Int?     @map("tokens_used")
  projectId      String?  @map("project_id")
  createdAt      DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id])

  @@map("conversation_messages")
}
