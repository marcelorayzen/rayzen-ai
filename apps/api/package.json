{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.6",
    "@bull-board/fastify": "^6.20.6",
    "@bull-board/nestjs": "^6.20.6",
    "@fastify/multipart": "^8.3.1",
    "@fastify/static": "^7.0.4",
    "@nestjs/bull": "^10.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/platform-fastify": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@notionhq/client": "^5.16.0",
    "@prisma/client": "^5.0.0",
    "@rayzen/types": "workspace:*",
    "axios": "^1.14.0",
    "bull": "^4.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "docxtemplater": "^3.0.0",
    "fastify": "^5.8.4",
    "form-data": "^4.0.5",
    "node-fetch": "^3.3.2",
    "openai": "^4.0.0",
    "pdf-parse": "1.1.1",
    "pizzip": "^3.0.0",
    "puppeteer": "^22.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/jest": "^29.5.14",
    "@types/pdf-parse": "^1.1.5",
    "jest": "^29.7.0",
    "prisma": "^5.0.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.4.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "modules/validation/**/*.(t|j)s",
      "modules/session/**/*.(t|j)s",
      "modules/voice/**/*.(t|j)s",
      "modules/memory/**/*.(t|j)s",
      "modules/execution/**/*.(t|j)s",
      "modules/orchestrator/**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/*.controller.ts",
      "!**/main.ts"
    ],
    "coverageThreshold": {
      "global": {
        "functions": 75,
        "branches": 30,
        "lines": 55
      }
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@rayzen/types$": "<rootDir>/../../packages/types/src/index.ts"
    }
  }
}
