# ─── LLM ──────────────────────────────────────────────
# Groq — gratuito, recomendado (console.groq.com)
GROQ_API_KEY=gsk_...

# OpenAI — opcional, usado como fallback no LiteLLM
OPENAI_API_KEY=sk-...

# ─── EMBEDDINGS ───────────────────────────────────────
# Jina AI — gratuito (jina.ai)
JINA_API_KEY=jina_...

# ─── LITELLM PROXY ────────────────────────────────────
LITELLM_MASTER_KEY=sk-rayzen-qualquercoisa
LITELLM_PORT=4000
# Usado pelo LiteLLM dentro do Docker (referencia o container postgres)
LITELLM_DATABASE_URL=postgresql://rayzen:senha@postgres:5432/rayzen_ai

# ─── BANCO DE DADOS ───────────────────────────────────
# Usado pela API (referencia localhost)
DATABASE_URL=postgresql://rayzen:senha@localhost:5432/rayzen_ai

# ─── REDIS ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AUTENTICAÇÃO ─────────────────────────────────────
# Gere com: openssl rand -hex 32
JWT_SECRET=gere-com-openssl-rand-hex-32
JWT_AGENT_EXPIRY=30d

# Senha de acesso ao painel web
ADMIN_PASSWORD=suasenha

# ─── PC AGENT ─────────────────────────────────────────
AGENT_POLL_INTERVAL_MS=3000
AGENT_API_URL=http://localhost:3001
AGENT_TOKEN=gere-um-token-aqui

# ─── APP ──────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
